{% extends 'base.html.twig' %}

{% block title %}Login - Nutrient Diary{% endblock %}

{% block body %}
    
        <div class="container d-flex justify-content-center pt-5">
            <div class="registration flex-fill">
                <h1>Login</h1>
                {% if error %}
                    <small class="text-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</small>
                {% endif %}
                <form action="{{ path('login') }}" method="post">
                    <div class="form-label"><label for="username">Email</label></div>
                    <input type="text" class="form-control" id="username" name="_username" value="{{ last_username }}">
                    <div class="form-label"><label for="password">Password</label></div>
                    <input type="password" class="form-control" id="password" name="_password">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-success registration-button mt-3 mb-3 d-grid gap-2 col-12 mx-auto">Login</button>
                </form>
            </div>
            </div>
     

{% endblock %}
